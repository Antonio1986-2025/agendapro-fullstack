# ===== Supabase =====
# URL do projeto + chaves (dashboard > Settings > API)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_KEY=sua-service-role-key

# ===== Supabase Database =====
# Use o Transaction Pooler (resolve IPv4, funciona em qualquer VPS)
# Encontre em: dashboard > Project Settings > Database > Connection string > Transaction pooler
# Se a senha tiver # substitua por %23 (URL-encode)
DATABASE_URL=postgresql://postgres.seu-projeto:SUA_SENHA@aws-1-us-east-1.pooler.supabase.com:6543/postgres
DB_SSL=true

# ===== Servidor =====
PORT=3000
NODE_ENV=development
AUTO_MIGRATE=true
TZ=America/Sao_Paulo

# ===== Autenticacao (JWT legado - sera substituido pelo Supabase Auth) =====
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-grande
JWT_EXPIRATION=7d

# ===== Evolution API (WhatsApp) =====
# URL da Evolution API (rodando no EasyPanel ou outro servidor)
EVOLUTION_API_URL=https://evolution.seu-dominio.com
# API Key global da Evolution API (configurada no AUTHENTICATION_API_KEY da Evolution)
EVOLUTION_API_KEY=sua-chave-global-da-evolution
# URL pública do seu sistema (para receber webhooks da Evolution)
SISTEMA_URL=https://seu-sistema.com

# ===== OpenAI (Agente IA) =====
OPENAI_API_KEY=sk-proj-sua-chave-openai
