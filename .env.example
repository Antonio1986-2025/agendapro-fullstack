# ===== Supabase =====
# URL do projeto + chaves (dashboard > Settings > API)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_KEY=sua-service-role-key

# ===== Supabase Database =====
# Use o Transaction Pooler (resolve IPv4, funciona em qualquer VPS)
# Encontre em: dashboard > Project Settings > Database > Connection string > Transaction pooler
# Se a senha tiver # substitua por %23 (URL-encode)
DATABASE_URL=postgresql://postgres.seu-projeto:SUA_SENHA@aws-1-us-east-1.pooler.supabase.com:6543/postgres
DB_SSL=true

# ===== Servidor =====
PORT=3000
NODE_ENV=development
AUTO_MIGRATE=true
TZ=America/Sao_Paulo

# ===== Autenticacao (JWT legado - sera substituido pelo Supabase Auth) =====
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-grande
JWT_EXPIRATION=7d
