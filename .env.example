# ===== Supabase =====
# URL do projeto + chaves (dashboard > Settings > API)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_KEY=sua-service-role-key

# ===== Supabase Database =====
# Usa variaveis separadas para evitar problemas com caracteres especiais na URL
# Dados em: dashboard > Project Settings > Database > Connection string
SUPABASE_DB_HOST=db.seu-projeto.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD="sua-senha-aqui"
SUPABASE_DB_NAME=postgres
SUPABASE_DB_SSL=true

# ===== Servidor =====
PORT=3000
NODE_ENV=development
AUTO_MIGRATE=true
TZ=America/Sao_Paulo

# ===== Autenticacao (JWT legado - sera substituido pelo Supabase Auth) =====
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-grande
JWT_EXPIRATION=7d
