# ===== Banco de dados =====
# Opcao A: usar uma unica URL (padrao EasyPanel/Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agendapro

# Opcao B: variaveis separadas (usadas se DATABASE_URL nao existir)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agendapro
DB_SSL=false

# ===== Servidor =====
PORT=3000
NODE_ENV=development
AUTO_MIGRATE=true
TZ=America/Sao_Paulo

# ===== Autenticacao =====
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-grande
JWT_EXPIRATION=7d
